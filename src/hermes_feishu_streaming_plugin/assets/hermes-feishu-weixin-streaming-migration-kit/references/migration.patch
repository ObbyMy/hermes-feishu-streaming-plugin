+class ToolStreamingAgent:
+    def __init__(self, **kwargs):
+        self.tool_progress_callback = kwargs.get("tool_progress_callback")
+        self.stream_delta_callback = kwargs.get("stream_delta_callback")
+        self.tools = []
+
+    def run_conversation(self, message, conversation_history=None, task_id=None):
+        if self.tool_progress_callback:
+            self.tool_progress_callback("tool.started", "terminal", "pwd", {})
+        time.sleep(0.15)
+        if self.stream_delta_callback:
+            self.stream_delta_callback("final answer")
+        if self.tool_progress_callback:
+            self.tool_progress_callback("tool.completed", "terminal", None, None, duration=0.15)
+        return {
+            "final_response": "final answer",
+            "messages": [],
+            "api_calls": 1,
+            "already_sent": True,
+        }
+
+
+class ToolPreviewThenFinalAgent:
+    def __init__(self, **kwargs):
+        self.tool_progress_callback = kwargs.get("tool_progress_callback")
+        self.stream_delta_callback = kwargs.get("stream_delta_callback")
+        self.interim_assistant_callback = kwargs.get("interim_assistant_callback")
+        self.tools = []
+
+    def run_conversation(self, message, conversation_history=None, task_id=None):
+        if self.stream_delta_callback:
+            self.stream_delta_callback("好")
+        if self.interim_assistant_callback:
+            self.interim_assistant_callback("好", already_streamed=True)
+        if self.tool_progress_callback:
+            self.tool_progress_callback("tool.started", "terminal", "pwd", {})
+        time.sleep(0.1)
+        if self.tool_progress_callback:
+            self.tool_progress_callback("tool.completed", "terminal", None, None, duration=0.1)
+        if self.stream_delta_callback:
+            self.stream_delta_callback("最终答案")
+        return {
+            "final_response": "最终答案",
+            "messages": [],
+            "api_calls": 1,
+            "already_sent": True,
+        }
+
